{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sqlfy",
  "version": "0.1.0",
  "identifier": "io.github.paulushcgcj.sqlfy",
  "build": {
    "frontendDist": "../../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SQLfy - Schema Graph Engine",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sqlfy"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "commands": [
        {
          "name": "python3",
          "cmd": "python3",
          "args": true,
          "sidecar": false
        },
        {
          "name": "binaries/sqlfy",
          "cmd": "binaries/sqlfy",
          "args": true,
          "sidecar": true
        }
      ]
    }
  }
}
